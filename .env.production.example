# ===========================================
# CC Scale Production Environment Variables
# ===========================================

# Cloudflare R2 (Media Storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# API Services
DATABASE_URL=postgresql://user:pass@host:5432/zzscale
REDIS_URL=redis://host:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Environment
NODE_ENV=production
PORT=8000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_STRICT=false

# CORS
CORS_ORIGIN=https://www.zzscale.com

# Frontend
NEXT_PUBLIC_API_URL=https://api.zzscale.com
NEXT_PUBLIC_WEB_URL=https://www.zzscale.com
NEXT_PUBLIC_MEDIA_URL=https://media.zzscale.com