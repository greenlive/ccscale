# Normalize line endings across the repository.
# Source code: LF. Windows batch scripts: CRLF.
* text=auto eol=lf

# Explicit overrides
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binary files — never touch
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.eot           binary
*.pdf           binary
*.zip           binary
*.gz            binary
*.tar           binary
