# CC Scale environment variables — TEMPLATE
# Copy to .env (NEVER commit), then fill in real values.
# Use: cp .env.example .env && edit
# 1Password reference: env-vault/1password-import.csv
#
# Generate secrets with:
#   openssl rand -base64 48    # JWT_SECRET, COOKIE_SECRET, R2 keys
#   openssl rand -hex 32       # SENTRY_DSN internal IDs
#
# NOTE: This file is committed; do NOT put real secrets here.

# ─────────────────────────────────────────────
# 1. API (NestJS) — used by apps/api
# ─────────────────────────────────────────────
NODE_ENV=production
PORT=8000
SITE_URL=https://www.ccscale.com
API_URL=https://api.ccscale.com

# Security (REQUIRED in production; >=32 chars)
JWT_SECRET=__REPLACE_WITH_openssl_rand_base64_48__
COOKIE_SECRET=__REPLACE_WITH_openssl_rand_base64_48__
COOKIE_DOMAIN=.ccscale.com
COOKIE_SECURE=true

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/ccscale?sslmode=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/ccscale?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@mail.ccscale.com
ADMIN_EMAIL=sales@ccscale.com

# CAPTCHA (Cloudflare Turnstile)
TURNSTILE_SITE_KEY=0x4AAAA0000000000000000000000000000
TURNSTILE_SECRET_KEY=0x4AAAA0000000000000000000000000000

# Object storage (Cloudflare R2, S3-compatible)
R2_ACCOUNT_ID=__REPLACE_WITH_32_hex__
R2_ACCESS_KEY_ID=__REPLACE_WITH_32_hex__
R2_SECRET_ACCESS_KEY=__REPLACE_WITH_base64_48__
R2_BUCKET=ccscale-media
R2_PUBLIC_URL=https://media.ccscale.com
R2_ENDPOINT=https://__ACCOUNT_ID__.r2.cloudflarestorage.com

# Upload limits
UPLOAD_MAX_SIZE_MB=20

# CORS — comma-separated allowed origins
CORS_ORIGIN=https://www.ccscale.com,https://admin.ccscale.com

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Monitoring
SENTRY_DSN=https://__KEY__@sentry.io/__PROJECT__

# Optional: seed (NEVER enable in production)
# ALLOW_SEED=1

# ─────────────────────────────────────────────
# 2. Web (Next.js marketing site) — used by apps/web
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.ccscale.com
NEXT_PUBLIC_SITE_URL=https://www.ccscale.com
NEXT_PUBLIC_MEDIA_URL=https://media.ccscale.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA0000000000000000000000000000
NEXT_PUBLIC_WHATSAPP_NUMBER=+8613800000000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://__KEY__@sentry.io/__PROJECT__

# ─────────────────────────────────────────────
# 3. Admin (Next.js admin) — used by apps/admin or apps/web/app/admin
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.ccscale.com
NEXT_PUBLIC_SITE_URL=https://admin.ccscale.com
COOKIE_DOMAIN=.ccscale.com

# ─────────────────────────────────────────────
# 4. Local dev overrides (uncomment as needed)
# ─────────────────────────────────────────────
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ccscale
# REDIS_URL=redis://localhost:6379
# LOG_LEVEL=debug
# TURNSTILE_BYPASS=true     # dev only — never set in prod
