# ===========================================
# CC Scale B2B Platform Environment Variables
# ===========================================

# Database
DATABASE_URL="postgresql://ccscale:ccscale123@localhost:5432/ccscale?schema=public"
POSTGRES_USER="ccscale"
POSTGRES_PASSWORD="ccscale123"
POSTGRES_DB="ccscale"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch
MEILISEARCH_URL="http://localhost:7700"
MEILI_MASTER_KEY="ccscale-master-key"

# API
API_URL="http://localhost:8000"
PORT="8000"
NODE_ENV="development"

# JWT Authentication (IMPORTANT: Change these in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="24h"

# Rate Limiting
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-password"
SMTP_FROM="noreply@ccscale.com"

# Admin
ADMIN_EMAIL="admin@ccscale.com"
ADMIN_URL="http://localhost:3001"

# Frontend URLs
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
