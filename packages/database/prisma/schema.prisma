generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Use PostgreSQL in production, SQLite for local development
  // To switch: change provider and DATABASE_URL in .env
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权限 ====================
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedInquiries Inquiry[] @relation("AssignedInquiries")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// ==================== 产品相关 ====================
model ProductCategory {
  id            Int       @id @default(autoincrement())
  nameEn        String
  nameZh        String
  slug          String    @unique
  imageUrl      String?
  descriptionEn String?
  descriptionZh String?
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      Product[]
}

model Product {
  id             Int              @id @default(autoincrement())
  categoryId     Int
  sku            String           @unique
  nameEn         String
  nameZh         String
  slug           String           @unique
  descriptionEn  String?
  descriptionZh  String?
  shortDescEn    String?
  shortDescZh    String?
  mainImages     String?  // JSON数组存储产品主图URLs (1-6张)
  detailImages   String?  // JSON数组存储详情图URLs (0-8张)
  videos         String?  // JSON数组存储视频URLs (0-3个)
  priceMin       Decimal?
  priceMax       Decimal?
  moq            Int?
  leadTime       String?
  order          Int              @default(0)
  isFeatured     Boolean          @default(false)
  isActive       Boolean          @default(true)
  seoTitleEn     String?
  seoTitleZh     String?
  seoDescEn      String?
  seoDescZh      String?
  seoKeywordsEn  String?
  seoKeywordsZh  String?
  // B2B 核心卖点（存储为JSON数组字符串）
  coreSellingPointsEn String?
  coreSellingPointsZh String?
  // B2B 应用场景
  applicationScenariosEn String?
  applicationScenariosZh String?
  // B2B FAQ（存储为JSON数组字符串）
  faqEn String?
  faqZh String?
  // B2B 认证（存储为JSON数组字符串，如 ["CE", "FCC", "RoHS"]）
  certifications String?
  // B2B 贸易信息
  hsCode String?
  paymentTerms String?
  shippingTerms String?
  warrantyInfo String?
  // B2B 包装信息
  packagingInfoEn String?
  packagingInfoZh String?
  // B2B 工厂信息
  manufacturerName String?
  factoryLocation String?
  productionCapacity String?
  productionCapacityUnit String?
  // B2B 贸易扩展信息
  fobPort String?
  tradeKeywords String?  // JSON数组字符串
  targetMarkets String?  // JSON数组字符串
  exportExperience String?
  // B2B 工厂实力（用于详情页展示，不在表单中编辑）
  factoryYears Int?
  factoryCountries Int?
  factoryCapacity String?
  factoryDescription String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  category       ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images         ProductImage[]
  specs          ProductSpec[]
  customerCases  CustomerCase[]
  inquiryItems   InquiryItem[]
}

model CustomerCase {
  id           Int      @id @default(autoincrement())
  productId    Int
  companyName  String
  logoUrl      String?
  quote        String?
  productName  String?
  region       String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        Int            @id @default(autoincrement())
  productId Int
  imageUrl  String
  altEn     String?
  altZh     String?
  order     Int            @default(0)
  type      ImageType      @default(MAIN)
  isMain    Boolean        @default(false)
  createdAt DateTime       @default(now())

  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ImageType {
  MAIN    // 主图/封面图 (1-5张)
  DETAIL  // 详情图/场景图 (0-8张)
}

model ProductSpec {
  id        Int      @id @default(autoincrement())
  productId Int
  keyEn     String
  keyZh     String
  valueEn   String
  valueZh   String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ==================== OEM/ODM 定制流程 ====================
model OemStep {
  id        Int      @id @default(autoincrement())
  titleEn   String
  titleZh   String
  descEn    String?
  descZh    String?
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== 询盘系统 ====================
model Inquiry {
  id            Int           @id @default(autoincrement())
  fullName      String
  email         String
  phone         String?
  whatsapp      String?
  company       String?
  country       String?
  city          String?
  message       String
  // 来源追踪
  source        String?
  trafficSource TrafficSource?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrer      String?
  ipAddress     String?
  userAgent     String?
  status        InquiryStatus @default(NEW)
  assignedToId  Int?
  notes         String?
  // 回复追踪
  repliedAt     DateTime?
  repliedBy     String?
  replyMethod   ReplyMethod?
  closedReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         InquiryItem[]
  assignedTo    User?         @relation("AssignedInquiries", fields: [assignedToId], references: [id])
  activities    ActivityLog[]
}

enum InquiryStatus {
  NEW
  READ
  IN_PROGRESS
  REPLIED
  CLOSED
  SPAM
}

enum ReplyMethod {
  EMAIL
  WHATSAPP
  PHONE
  ALIBABA
  LINKEDIN
  OTHER
}

enum TrafficSource {
  DIRECT
  ORGANIC_SEARCH
  PAID_SEARCH
  SOCIAL_ORGANIC
  SOCIAL_PAID
  REFERRAL
  EMAIL
  AI_SEARCH
  DISPLAY
  VIDEO
  OTHER
}

// 询盘操作日志
model ActivityLog {
  id          Int      @id @default(autoincrement())
  inquiryId   Int
  action      String
  detail      String?
  performedBy String
  createdAt   DateTime @default(now())

  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model InquiryItem {
  id           Int       @id @default(autoincrement())
  inquiryId    Int
  productId    Int?
  productNameEn String?
  productNameZh String?
  quantity     Int?
  unitPrice    Decimal?
  notes        String?
  createdAt    DateTime  @default(now())

  inquiry      Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ==================== 内容管理 ====================
model Testimonial {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameZh    String
  companyEn String?
  companyZh String?
  countryEn String?
  countryZh String?
  avatarUrl String?
  contentEn String
  contentZh String
  rating    Int      @default(5)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Client {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameZh    String
  logoUrl   String
  website   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Download {
  id            Int      @id @default(autoincrement())
  titleEn       String
  titleZh       String
  descriptionEn String?
  descriptionZh String?
  fileUrl       String
  fileType      String
  fileSize      Int?
  category      String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model PageContent {
  id        Int      @id @default(autoincrement())
  pageKey   String   @unique
  titleEn   String
  titleZh   String
  contentEn String?
  contentZh String?
  metaEn    String?
  metaZh    String?
  updatedAt DateTime @updatedAt
}

// ==================== 用户行为统计 ====================
model UserSession {
  id          Int      @id @default(autoincrement())
  sessionId   String   @unique
  ipAddress   String?
  country     String?
  region      String?
  city        String?
  userAgent   String?
  deviceType  String?
  browser     String?
  os          String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  trafficSource TrafficSource @default(DIRECT)
  referrer    String?
  landingPage String?
  firstVisit  DateTime @default(now())
  lastVisit   DateTime @default(now())
  pageViews   Int      @default(0)

  events      SessionEvent[]
}

model SessionEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  eventType String
  pageUrl   String?
  productId Int?
  data      String?
  createdAt DateTime @default(now())

  session   UserSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
}

// ==================== 网站设置 ====================
model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String?
}
